<!DOCTYPE html>
<html lang="en">

<head>
    <%- include("partials/head.ejs") %>
</head>

<body>
    <h1 class="bg-info text-white p-3 mb-0">The Solar System</h1>
    <%- include("partials/nav.ejs") %>

        <div class="container-fluid m-5 row">
            <div class="card p-4 col">
                <h2>
                    <%=planet%>
                </h2>

                <% if (planetInfo.description) { %>
                    <p>
                        <%= planetInfo.description %>
                    </p>
                    <% } else if (planetInfo.def) { %>
                        <p>
                            <%= planetInfo.def %>
                        </p>
                        <% } else { %>
                            <p>No description available.</p>
                            <% } %>
            </div>

            <div class="card col">
                <img src="<%=planetInfo.image %>" alt="">
            </div>

        </div>
</body>

</html>